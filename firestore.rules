rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSeller() {
      return isSignedIn() && getUserRole() == 'seller';
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true;
      allow read: if isSignedIn() &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isSeller() &&
        request.resource.data.sellerId == request.auth.uid;
      allow update: if isSeller() &&
        resource.data.sellerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (isSeller() && resource.data.sellerId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow read: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow update: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin();
      allow update: if isSeller();
    }

    match /cart/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /storefronts/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /notifications/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
